# ---------------------------------------------------------------------------
# Monorepo root ignore. Patterns use **/ so they match inside every workspace
# (frontend / backend / packages/*).
# ---------------------------------------------------------------------------

# dependencies
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing / coverage
coverage/

# next.js
**/.next/
**/.next-dev/
**/out/

# nest.js / typescript build output
**/dist/
*.tsbuildinfo
next-env.d.ts

# prisma generated client (regenerated by `prisma generate`)
backend/node_modules/.prisma/

# production
build/

# local uploads (when the local-disk storage provider is used in dev)
backend/uploads/

# misc
.DS_Store
*.pem

# debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (every workspace) — commit only the *.example variants
.env
.env.*
!.env.example
!**/.env.example

# vercel
.vercel

# IDE
/.idea/

# test / verification artifacts
**/scripts/*.png
**/scripts/*.log
