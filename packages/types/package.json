{
  "name": "@resume/types",
  "version": "1.0.0",
  "private": true,
  "description": "Shared ResumeData contract types mirrored from the frontend (frontend/src/types is the source of truth).",
  "main": "dist/index.js",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  }
}
