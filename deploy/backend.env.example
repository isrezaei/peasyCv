# ===========================================================================
# Backend application config for the Docker deployment.
# Copy to `deploy/backend.env` and fill in the blanks:
#
#   cp deploy/backend.env.example deploy/backend.env
#
# This file is loaded by the `backend` service (env_file) in
# docker-compose.prod.yml. Values marked (REQUIRED) MUST be set before going
# live. NOTE: DATABASE_URL is assembled automatically by compose from the
# POSTGRES_* vars in the root .env — do NOT set it here.
#
# فایل تنظیمات بک‌اند. مقادیر لازم را پر کنید و با نام `deploy/backend.env` ذخیره کنید.
# ===========================================================================

# --- Server ----------------------------------------------------------------
# NODE_ENV / PORT are set by compose. In production, CORS is locked to
# localhost + the origins below.
#
# CORS allow-list (comma-separated, no spaces). Exactly the origins the browser
# will send. localhost is ALWAYS allowed by the API regardless of this value.
FRONTEND_ORIGIN=https://studio.peasycv.ir,http://studio.peasycv.ir

# Public URL of the studio frontend — used to build public SHARE links
# (https://studio.peasycv.ir/share/<token>). (REQUIRED) Set to your real domain.
FRONTEND_URL=https://studio.peasycv.ir

# INTERNAL URL Puppeteer loads to render PDFs (the /print route). Inside the
# compose network the frontend service is reachable at http://frontend:3000 —
# keep this as-is unless you renamed the service. Kept separate from FRONTEND_URL
# so PDF rendering does NOT round-trip out through your public proxy. If unset,
# it falls back to FRONTEND_URL.
PDF_FRONTEND_URL=http://frontend:3000

# Public base URL of THIS API (Swagger server list + share-link fallback).
# (REQUIRED) e.g. https://api.peasycv.ir
API_URL=https://api.peasycv.ir

# --- JWT (REQUIRED — use long random secrets) ------------------------------
# Generate with:  openssl rand -hex 48
JWT_ACCESS_SECRET=CHANGE_ME_long_random_access_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=CHANGE_ME_long_random_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d

# --- Google OAuth (optional — leave CLIENT_ID/SECRET blank to disable) ------
# Add GOOGLE_CALLBACK_URL to the OAuth client's Authorized redirect URIs.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://api.peasycv.ir/auth/google/callback
# Where the API sends the browser (with tokens) after a successful Google login.
OAUTH_SUCCESS_REDIRECT=https://studio.peasycv.ir/auth/callback

# --- Profile-image storage --------------------------------------------------
# One of: local | s3 | cloudinary.
#   local      -> writes to /app/backend/uploads (a Docker volume persists it);
#                 served at LOCAL_UPLOAD_BASE_URL. Fine for a single host.
#   s3 / cloudinary -> recommended for production; fill the block below.
STORAGE_PROVIDER=local
LOCAL_UPLOAD_DIR=uploads
# Must be publicly reachable by the browser (usually API_URL + /uploads).
LOCAL_UPLOAD_BASE_URL=https://api.peasycv.ir/uploads

# S3 (when STORAGE_PROVIDER=s3) — (REQUIRED for that provider)
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Optional: custom public base URL (CDN) and S3-compatible endpoint (R2/MinIO).
S3_PUBLIC_BASE_URL=
S3_ENDPOINT=

# Cloudinary (when STORAGE_PROVIDER=cloudinary) — (REQUIRED for that provider)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=resume-profile-images

# --- PDF (Puppeteer / Chromium) --------------------------------------------
# Chromium is installed in the backend image at this path; leave as-is.
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
PDF_RENDER_TIMEOUT_MS=60000
