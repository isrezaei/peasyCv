{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.ts$": ["ts-jest", { "tsconfig": "<rootDir>/../tsconfig.json" }]
  },
  "moduleNameMapper": {
    "^@resume/types$": "<rootDir>/../../packages/types/src/index.ts",
    "^@/(.*)$": "<rootDir>/../src/$1"
  },
  "testEnvironment": "node",
  "testTimeout": 30000
}
