// Prisma schema for the resume builder.
//
// The data model maps 1:1 to the frontend `ResumeData` contract
// (frontend/src/types, mirrored in packages/types). Design rules:
//   * Every list-shaped section is a normalized child table with a `position`
//     column so array ordering round-trips exactly.
//   * Item primary keys are the CLIENT-provided ids (UUIDs from crypto.randomUUID)
//     so ids stay stable between the store, the API and the database.
//   * The fixed-shape singletons (theme, personalInfo) are 1:1 child tables with
//     explicit scalar columns — no JSON blobs for content — so the DB -> API ->
//     store round-trip is byte-for-byte shape-identical.
//   * Timestamps are server-authoritative (createdAt default, updatedAt @updatedAt)
//     and serialized to ISO strings.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Auth
// ---------------------------------------------------------------------------

model User {
  id                 String   @id @default(uuid())
  email              String   @unique
  // Null for accounts created purely via Google OAuth (no local password).
  passwordHash       String?
  name               String?
  // Optional contact phone shown in the admin users table. Nothing collects it
  // yet (empty for everyone); deliberately separate from resume-content phone.
  phone              String?
  // Admin-dashboard access. NEVER settable from any client payload: absent from
  // every DTO, and granted only out-of-band (manual UPDATE or the seed script).
  isAdmin            Boolean  @default(false)
  // Google OAuth subject id; null for email/password-only accounts.
  googleId           String?  @unique
  // Hashed (bcrypt) current refresh token for rotation/revocation. Null = logged out.
  hashedRefreshToken String?
  // Self-declared occupation picked from a fixed list at email/password signup
  // (see OCCUPATION_IDS). Null for existing accounts and for Google-OAuth signups
  // (the form is bypassed) — aggregated as "unspecified" in the admin panel.
  occupation         String?
  // Broad occupation CATEGORY driving the resume's tailored default/example
  // content (see OCCUPATION_CATEGORY_IDS — 10 Iran-focused families + "azad").
  // Nullable: existing users and fresh OAuth signups have no category until the
  // one-time post-login prompt; null = "not chosen yet", never a display value.
  occupationCategory String?
  resumes            Resume[]
  assets             Asset[]
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// Uploaded image assets (profile photos). Kept separate from resume content:
// the binary lives in cloud storage, only the metadata/URL is recorded here, and
// the resume references the URL through personalInfo.profileImage (ImageMeta).
model Asset {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider  String // "local" | "s3" | "cloudinary"
  key       String // storage key / public_id / relative path
  url       String
  width     Int?
  height    Int?
  bytes     Int?
  mime      String?
  createdAt DateTime @default(now())

  @@index([userId])
}

// ---------------------------------------------------------------------------
// Metrics events (admin dashboard). Deliberately NOT related to Resume/User —
// events must survive resume/user deletion, and joins are never needed.
// ---------------------------------------------------------------------------

// One row per unique visitor per UTC day. `visitorId` is an opaque random UUID
// minted client-side (first-party, localStorage) — no IP, no user agent, never
// joined to User. The unique constraint IS the dedup: daily visitor count =
// COUNT(rows) per date.
model VisitEvent {
  id        String @id @default(uuid())
  visitorId String
  date      String // UTC day bucket, "YYYY-MM-DD"

  @@unique([visitorId, date])
  @@index([date])
}

// One row per successful server-side PDF render (recorded in the PDF
// controller, never client-side). userId is null only for public share-link
// downloads; resumeId is a plain string (not a relation) so history outlives
// the resume.
model DownloadEvent {
  id        String   @id @default(uuid())
  userId    String?
  resumeId  String?
  source    String // "editor" | "share"
  date      String // UTC day bucket, "YYYY-MM-DD" — enables plain groupBy
  // Selection snapshot of the résumé AS RENDERED, captured server-side in the PDF
  // controller (never client-supplied). Enables "downloads per option per day" as
  // a plain groupBy — no join, no extra table. Null on rows written before this
  // column existed.
  templateId        String?
  themeId           String?
  backgroundPattern String?
  fontId            String?
  createdAt DateTime @default(now())

  @@index([date])
}

// Product analytics for what users CHOOSE (background / colour / template / font).
// One generic table + a `kind` discriminator instead of four parallel tables:
// adding a new dimension (e.g. "font" — already wired) needs ZERO schema change,
// just a new `kind` string. Deliberately anonymous: kind/value/date only — no
// userId, no IP — these are aggregate product metrics, not user tracking. Written
// by the @Public() /selections beacon only when the user actually changes a
// setting (never on load/hydration).
model SelectionEvent {
  id        String   @id @default(uuid())
  kind      String // "background" | "theme" | "template" | "font"
  value     String // the chosen id, e.g. "sidebar-column" / "navyGold" / "dotGrid"
  date      String // UTC day bucket, "YYYY-MM-DD" — matches VisitEvent's convention
  createdAt DateTime @default(now())

  @@index([kind, date])
}

// ---------------------------------------------------------------------------
// Resume (root) + 1:1 singletons
// ---------------------------------------------------------------------------

model Resume {
  // Client-provided UUID (createId()) so the store id == API id == DB id.
  id          String   @id
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  locale      String   @default("fa") // "fa" | "en"
  templateId  String
  // Per-resume occupation-category id (OCCUPATION_CATEGORY_IDS; validated with
  // @IsIn at the DTO). Nullable: resumes created before the field existed, or
  // by users who never chose, have null — the frontend renders the «آزاد»
  // fallback. Defaults at creation to the owner's User.occupationCategory.
  occupationCategory String?
  // summary is { html }; stored as a single column and re-wrapped on read.
  summaryHtml String   @default("")

  // Public read-only share.
  shareToken   String?  @unique
  shareEnabled Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  theme          ResumeTheme?
  personalInfo   ResumePersonalInfo?
  links          PersonalLink[]
  sections       Section[]
  experiences    Experience[]
  skillGroups    SkillGroup[]
  educations     Education[]
  projects       Project[]
  languages      Language[]
  certifications Certification[]
  achievements   Achievement[]

  @@index([userId])
}

model ResumeTheme {
  id                  String @id @default(uuid())
  resumeId            String @unique
  resume              Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  themeId             String
  // DEAD COLUMN — page is always white now; retained so old rows still load. No
  // destructive migration. Safe to drop once no stored theme carries a value.
  pageBackground      String
  backgroundPattern   String
  backgroundIntensity Float
  dateCalendar        String
  fontFamily          String
  fontScale           Float
  lineHeight          Float
  pageMargin          Float
  sectionSpacing      Float
  columnIntensity     Float
  columnWidth         String  @default("medium")
  showSectionIcons    Boolean @default(false)
  showSectionSeparators Boolean @default(false)
  // DEAD COLUMN — the "modern column style" feature was removed; nothing reads or
  // writes this anymore (the serializer/DTO dropped it), but the column is kept so
  // no destructive migration is needed. Safe to drop in a later cleanup migration.
  columnStyle         String  @default("classic")
  atsMode             Boolean @default(false)
}

model ResumePersonalInfo {
  id       String @id @default(uuid())
  resumeId String @unique
  resume   Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  fullName      String  @default("")
  jobTitle      String  @default("")
  phone         String  @default("")
  location      String  @default("")
  email         String  @default("")
  dateOfBirth     String  @default("")
  nationality     String  @default("")
  militaryService String  @default("")
  uppercaseName   Boolean @default(false)
  photoStyle    String  @default("round") // "round" | "square"
  imageSide     String  @default("left") // "left" | "right"

  // PersonalInfoFieldVisibility (fv* = field visibility flags).
  fvJobTitle    Boolean @default(true)
  fvPhone       Boolean @default(true)
  fvLinks       Boolean @default(true)
  fvEmail       Boolean @default(true)
  fvLocation    Boolean @default(true)
  fvPhoto       Boolean @default(true)
  fvDateOfBirth     Boolean @default(false)
  fvNationality     Boolean @default(false)
  fvMilitaryService Boolean @default(false)

  // profileImage (ImageMeta | null). When photoMetaId is null the whole
  // profileImage serializes to null. When photoCropZoom is null, crop is null.
  photoMetaId      String?
  photoUrl         String?
  photoOriginalUrl String?
  photoWidth       Float?
  photoHeight      Float?
  photoCropX       Float?
  photoCropY       Float?
  photoCropWidth   Float?
  photoCropHeight  Float?
  photoCropZoom    Float?
}

// ---------------------------------------------------------------------------
// Normalized collections (each carries `position` for stable array order)
// ---------------------------------------------------------------------------

model PersonalLink {
  id       String @id // client id
  resumeId String
  resume   Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  label    String @default("")
  url      String @default("")
  position Int

  @@index([resumeId])
}

model Section {
  id        String  @id // client id
  resumeId  String
  resume    Resume  @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  type      String // RemovableSectionType
  title     String
  visible   Boolean
  direction String // "rtl" | "ltr"
  order     Int
  // Languages-section display settings — section-wide, meaningful only for
  // type "languages" but defaulted on every row like `direction`.
  languageMeterVariant  String  @default("bars") // LanguageMeterVariant
  languageShowMeter     Boolean @default(true)
  languageShowLevelText Boolean @default(true)
  // Period-date display settings — section-wide, meaningful for the dated
  // sections ("experience", "education") but defaulted on every row like the
  // languages settings. Each section row keeps its own independent pair.
  showMonth   Boolean @default(true)
  monthFormat String  @default("name") // MonthFormat: "name" | "number"
  // Achievements display settings — section-wide, meaningful only for type
  // "achievements" but defaulted on every row like the languages settings.
  achievementShowDescription Boolean @default(true)
  achievementShowIcons       Boolean @default(true)
  // Skills display settings — section-wide, meaningful only for type "skills"
  // but defaulted on every row like the languages settings. The per-group title
  // toggle lives on the SkillGroup row itself.
  skillDisplayMode  String  @default("row") // SkillDisplayMode: "row" | "list"
  skillShowLevel    Boolean @default(false)
  skillMeterVariant String  @default("line") // SkillMeterVariant (no "pill")

  @@index([resumeId])
}

model Experience {
  id                 String           @id // client id
  resumeId           String
  resume             Resume           @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  jobTitle           String           @default("")
  companyName        String           @default("")
  periodStart        String           @default("")
  periodEnd          String           @default("")
  periodCurrent      Boolean          @default(false)
  city               String           @default("")
  projectLink        String           @default("")
  projectDescription String           @default("")
  // External link + visibility flag, mirroring Project.link / Project.linkVisible.
  link               String           @default("")
  linkVisible        Boolean          @default(true)
  position           Int
  responsibilities   Responsibility[]

  @@index([resumeId])
}

model Responsibility {
  id           String     @id // client id
  experienceId String
  experience   Experience @relation(fields: [experienceId], references: [id], onDelete: Cascade)
  text         String     @default("")
  position     Int

  @@index([experienceId])
}

model SkillGroup {
  id       String  @id // client id
  resumeId String
  resume   Resume  @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  name     String  @default("")
  // Whether the group's title row renders — per group, not section-wide.
  showTitle Boolean @default(true)
  position Int
  skills   Skill[]

  @@index([resumeId])
}

model Skill {
  id       String     @id // client id
  groupId  String
  group    SkillGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  name     String     @default("")
  // Proficiency on the shared 1–5 scale (LanguageLevel); rendered only when the
  // section-wide skillShowLevel toggle is on, but always stored.
  level    Int        @default(3)
  position Int

  @@index([groupId])
}

model Education {
  id          String @id // client id
  resumeId    String
  resume      Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  degree      String @default("")
  university  String @default("")
  startDate   String @default("")
  endDate     String @default("")
  gpa         String @default("")
  achievements String @default("")
  city        String @default("")
  position    Int

  @@index([resumeId])
}

model Project {
  id          String @id // client id
  resumeId    String
  resume      Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  name        String @default("")
  role        String @default("")
  link        String @default("")
  linkVisible Boolean @default(true)
  description String @default("")
  position    Int

  @@index([resumeId])
}

model Language {
  id       String @id // client id
  resumeId String
  resume   Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  name     String @default("")
  level    Int // LanguageLevel 1..5
  showBars      Boolean @default(true)
  showLevelText Boolean @default(true)
  position Int

  @@index([resumeId])
}

model Certification {
  id       String @id // client id
  resumeId String
  resume   Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  name     String @default("")
  issuer   String @default("")
  date     String @default("")
  position Int

  @@index([resumeId])
}

model Achievement {
  id          String @id // client id
  resumeId    String
  resume      Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  title       String @default("")
  description String @default("")
  position    Int

  @@index([resumeId])
}
