# ===========================================================================
# Backend environment. Copy to `backend/.env` and fill in the blanks.
#
#   cp backend/.env.example backend/.env
#
# Values marked (REQUIRED) must be set for the feature to work; everything else
# has a working local default.
# ===========================================================================

# --- Server ----------------------------------------------------------------
PORT=4000
NODE_ENV=development
# Comma-separated list of origins allowed by CORS (the frontend dev/prod URLs).
FRONTEND_ORIGIN=http://localhost:3000
# Public URL the Next.js frontend is served at. Used to (a) build share links and
# (b) render the PDF by pointing Puppeteer at the frontend's /print route.
FRONTEND_URL=http://localhost:3000
# Public base URL of THIS API (used in Swagger server list + share-link fallback).
API_URL=http://localhost:4000

# --- Database (matches root docker-compose Postgres) -----------------------
DATABASE_URL=postgresql://resume:resume_password@localhost:5432/resume_builder?schema=public

# --- JWT (REQUIRED in production: use long random secrets) ------------------
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_REFRESH_EXPIRES_IN=7d

# --- Google OAuth (optional — leave CLIENT_ID/SECRET blank to disable) ------
# Create an OAuth 2.0 Client (type: Web application) at
# https://console.cloud.google.com/apis/credentials and add the callback URL
# below to its "Authorized redirect URIs".
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/auth/google/callback
# After a successful Google login the API redirects the browser here with the
# tokens in the query string; the frontend route reads + stores them.
OAUTH_SUCCESS_REDIRECT=http://localhost:3000/auth/callback

# --- Profile-image storage provider ----------------------------------------
# One of: "local" | "s3" | "cloudinary".
#   local      -> writes to backend/uploads and serves via LOCAL_UPLOAD_BASE_URL
#                 (dev only; no external credentials required).
#   s3         -> requires the S3_* vars below.
#   cloudinary -> requires the CLOUDINARY_* vars below.
STORAGE_PROVIDER=local
LOCAL_UPLOAD_DIR=uploads
LOCAL_UPLOAD_BASE_URL=http://localhost:4000/uploads

# S3 (when STORAGE_PROVIDER=s3) — (REQUIRED for that provider)
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Optional: custom public base URL (CDN) and S3-compatible endpoint (e.g. R2/MinIO).
S3_PUBLIC_BASE_URL=
S3_ENDPOINT=

# Cloudinary (when STORAGE_PROVIDER=cloudinary) — (REQUIRED for that provider)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=resume-profile-images

# --- PDF (Puppeteer) -------------------------------------------------------
# Path to a Chrome/Chromium executable. Leave blank to auto-detect a system
# Chrome install. puppeteer-core does NOT download a browser.
PUPPETEER_EXECUTABLE_PATH=
# Max milliseconds to wait for the print page to become render-ready.
PDF_RENDER_TIMEOUT_MS=60000
