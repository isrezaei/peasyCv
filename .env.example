# ---------------------------------------------------------------------------
# Root env — consumed by docker-compose.yml for the local Postgres container.
# Copy to `.env` (the values below are the defaults the backend expects).
#
#   cp .env.example .env
#
# The backend has its OWN env file (backend/.env, see backend/.env.example).
# Keep POSTGRES_* here in sync with DATABASE_URL there.
# ---------------------------------------------------------------------------
POSTGRES_USER=resume
POSTGRES_PASSWORD=resume_password
POSTGRES_DB=resume_builder
POSTGRES_PORT=5432
ADMINER_PORT=8080
